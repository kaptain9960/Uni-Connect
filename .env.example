# Copy this file to .env (same folder as manage.py) and fill in real values.
# .env is loaded automatically by settings.py — no extra setup needed.
# Never commit your real .env file to version control.

# ---------------------------------------------------------------------------
# EMAIL — required for real password-reset / verification emails to be sent
# ---------------------------------------------------------------------------
# Leave EMAIL_HOST_USER and EMAIL_HOST_PASSWORD blank/unset to keep using the
# local file-based backend (emails are written to sent_emails/ instead of
# being delivered — fine for development, but forgot-password won't reach a
# real inbox). Fill them in to send real emails, in development or
# production alike.
#
# OPTION A — Gmail (free, quick to set up, fine for a student project)
#   1. Turn on 2-Step Verification on the Google account you want to send
#      from: https://myaccount.google.com/security
#   2. Create an "App Password": https://myaccount.google.com/apppasswords
#      (choose "Mail" as the app). Google gives you a 16-character password
#      — use THAT here, not your normal Gmail password (Gmail blocks normal
#      passwords for SMTP).
#   3. Fill in below:
#        EMAIL_HOST_USER=youraccount@gmail.com
#        EMAIL_HOST_PASSWORD=the16characterapppassword
#        EMAIL_HOST=smtp.gmail.com
#        EMAIL_PORT=587
#        EMAIL_USE_TLS=True
#
# OPTION B — SendGrid / Mailgun / Outlook / any other SMTP provider
#   Use the SMTP host/port/credentials your provider gives you, e.g.:
#        EMAIL_HOST_USER=apikey                     # SendGrid literally uses this username
#        EMAIL_HOST_PASSWORD=SG.xxxxxxxxxxxxxxxxx    # your API key
#        EMAIL_HOST=smtp.sendgrid.net
#        EMAIL_PORT=587
#        EMAIL_USE_TLS=True
#
# After filling this in, verify it actually works before relying on it:
#     python manage.py send_test_email you@example.com
#
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False

# The From address students/lecturers will see on password-reset emails.
# You do not need to own this domain for Gmail/SendGrid/etc. to accept it as
# a display name, but using your actual sending address avoids spam filters:
DEFAULT_FROM_EMAIL=Uni-Connect <youraccount@gmail.com>

# ---------------------------------------------------------------------------
# Everything below is optional / unrelated to email — included for reference
# ---------------------------------------------------------------------------
# DJANGO_SECRET_KEY=change-me-to-a-random-value-in-production
# DJANGO_DEBUG=True
# DATABASE_URL=postgres://user:password@host:5432/dbname
